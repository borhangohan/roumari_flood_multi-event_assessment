var S1_FOLDER  = 'projects/ee-2221128/assets/sen1floods11/S1Hand';
var LBL_FOLDER = 'projects/ee-2221128/assets/sen1floods11/LabelHand';

function chipStem(assetId) {
  var name = assetId.split('/').pop();
  name = name.replace(/_S1Hand$/, '');
  name = name.replace(/_LabelHand$/, '');
  return name;
}

ee.data.listAssets(S1_FOLDER, {}, function(s1List, s1Err) {
  if (s1Err || !s1List || !s1List.assets || s1List.assets.length === 0) {
    print('ERROR loading S1Hand folder: ' + s1Err);
    return;
  }

  ee.data.listAssets(LBL_FOLDER, {}, function(lblList, lblErr) {
    if (lblErr || !lblList || !lblList.assets || lblList.assets.length === 0) {
      print('ERROR loading LabelHand folder: ' + lblErr);
      return;
    }

    print('S1Hand chips found    : ' + s1List.assets.length);
    print('LabelHand chips found : ' + lblList.assets.length);

    var lblById = {};
    lblList.assets.forEach(function(a) {
      lblById[chipStem(a.id)] = a.id;
    });

    var matchedS1Ids  = [];
    var matchedLblIds = [];
    var skipped       = [];

    s1List.assets.forEach(function(a) {
      var stem = chipStem(a.id);
      if (lblById[stem]) {
        matchedS1Ids.push(a.id);
        matchedLblIds.push(lblById[stem]);
      } else {
        skipped.push(stem);
      }
    });

    print('Matched chip pairs    : ' + matchedS1Ids.length);
    if (skipped.length > 0) {
      print('WARNING — S1 chips with no label match: ' + skipped.join(', '));
    }

    if (matchedS1Ids.length === 0) {
      print('ERROR: No matched chip pairs found. Check asset naming convention.');
      return;
    }

    var chipImages = matchedS1Ids.map(function(s1Id, i) {
      var s1img  = ee.Image(s1Id);
      var lblImg = ee.Image(matchedLblIds[i]);

      var vv = s1img.select([0]).rename('VV');
      var vh = s1img.select([1]).rename('VH');

      var ratio   = vv.subtract(vh).rename('VV_VH_ratio');
      var vhLin   = ee.Image(10).pow(vh.divide(10));
      var texture = vhLin.reduceNeighborhood({
        reducer: ee.Reducer.variance(), kernel: ee.Kernel.square(1)
      }).rename('VH_texture');

      var rawLbl = lblImg.select([0]);
      var lbl = rawLbl.rename('class')
        .updateMask(rawLbl.eq(0).or(rawLbl.eq(1)));

      return vv.addBands(vh).addBands(ratio).addBands(texture).addBands(lbl)
        .set('chip_stem', chipStem(s1Id));
    });

    var s11_chipCol = ee.ImageCollection(chipImages);

    var s11_allPts = s11_chipCol.map(function(chip) {
      return ee.Image(chip).stratifiedSample({
        numPoints:  THR.s11_px_per_chip,
        classBand:  'class',
        region:     ee.Image(chip).geometry(),
        scale:      10,
        seed:       42,
        geometries: true
      }).map(function(f) {
        return f.set('chip_stem', chip.get('chip_stem'));
      });
    }).flatten();

    s11_allPts.size().evaluate(function(n, e) {
      print('Sen1Floods11 training pixels (all chips): ' + (e ? 'ERROR: '+e : n));
    });

    // ── Stage 1 classifier (all chips, probability mode) ────────────────────
    var s11_clf = ee.Classifier.smileRandomForest({
      numberOfTrees: RF_TREES, variablesPerSplit: 2,
      minLeafPopulation: 5, seed: 42
    }).setOutputMode('PROBABILITY')
      .train({features: s11_allPts, classProperty: 'class', inputProperties: S11_FEAT});

    var roumariS11Stack = vvFlood.rename('VV')
      .addBands(vhFlood.rename('VH'))
      .addBands(vvVhRatio.rename('VV_VH_ratio'))
      .addBands(vhTexture.rename('VH_texture'))
      .clip(AOI).unmask(THR.rf_fill);

    var s11_prob_roumari = roumariS11Stack
      .classify(s11_clf)
      .updateMask(s1Mask)
      .rename('s11_prob');

    var s11_bin      = s11_prob_roumari.gte(THR.rf_prob).toInt().rename('flood');
    var floodMap_S11 = postProcess(s11_bin, 'C-RF-S11(Stage1)');

    Map.addLayer(s11_prob_roumari,
      {min:0,max:1,palette:['white','#ffd580','#b35c00']}, '4a. C-RF-S11 Prob (Stage 1)', false);
    Map.addLayer(floodMap_S11.selfMask(),
      {palette:['#e67e22']}, '4a. C-RF-S11 Map (Stage 1)', false);

    // ── Stage 1 feature importance ──────────────────────────────────────────
    var s11_clfClass = ee.Classifier.smileRandomForest({
      numberOfTrees: RF_TREES, variablesPerSplit: 2,
      minLeafPopulation: 5, seed: 42
    }).setOutputMode('CLASSIFICATION')
      .train({features: s11_allPts, classProperty: 'class', inputProperties: S11_FEAT});

    s11_clfClass.explain().evaluate(function(exp, err) {
      if (err || !exp || !exp.importance) {
        print('  [Stage 1 importance ERROR] ' + err); return;
      }
      var imp   = exp.importance;
      var pairs = S11_FEAT.map(function(f){ return {f:f, v:imp[f]||0}; });
      pairs.sort(function(a,b){ return b.v-a.v; });
      var tot = pairs.reduce(function(s,p){ return s+p.v; },0);
      print('');
      print('  ── STAGE 1 (Sen1Floods11) FEATURE IMPORTANCE ────────────────────────');
      pairs.forEach(function(p){
        var pct = tot>0 ? (p.v/tot*100).toFixed(1) : '0.0';
        var bar = ''; var bl = Math.round(p.v/tot*30);
        for(var i=0;i<bl;i++) bar+='█';
        for(var j=bl;j<30;j++) bar+='░';
        print('  '+lp(p.f,20)+lp(pct+'%',10)+bar);
      });
    });

    // ── Serialized cross-chip leave-one-out CV ──────────────────────────────
    print('');
    print('  ── SEN1FLOODS11 CROSS-CHIP CV (leave-one-chip-out) — SERIALIZED ────────');
    print('  One chip withheld per fold. Remaining chips train Stage 1 RF.');

    var allStems = matchedS1Ids.map(function(id){ return chipStem(id); });
    var nChips   = allStems.length;
    print('  Total chips: ' + nChips + ' | Running ' + nChips + '-fold CV (one fold at a time)...');

    var cvTP = 0, cvTN = 0, cvFP = 0, cvFN = 0;

    function printCVAggregate() {
      var tot2 = cvTP+cvTN+cvFP+cvFN;
      if (tot2 === 0) { print('  [CV aggregate ERROR] No valid fold results.'); return; }
      var OA   = (cvTP+cvTN)/tot2;
      var PA   = cvTP/(cvTP+cvFN);
      var UA   = (cvTP+cvFP)>0 ? cvTP/(cvTP+cvFP) : 0;
      var spec = (cvTN+cvFP)>0 ? cvTN/(cvTN+cvFP) : 0;
      var BA   = (PA+spec)/2;
      var F1   = (2*cvTP+cvFP+cvFN)>0 ? 2*cvTP/(2*cvTP+cvFP+cvFN) : 0;
      var CSI  = (cvTP+cvFP+cvFN)>0 ? cvTP/(cvTP+cvFP+cvFN) : 0;
      var pe   = ((cvTP+cvFP)*(cvTP+cvFN)+(cvTN+cvFN)*(cvTN+cvFP))/(tot2*tot2);
      var kap  = (OA-pe)/(1-pe);
      print('');
      print('  ── AGGREGATE CROSS-CHIP CV RESULTS ──────────────────────────────────');
      print('  n='+tot2+' | TP='+cvTP+' TN='+cvTN+' FP='+cvFP+' FN='+cvFN);
      print('  OA='+(OA*100).toFixed(1)+'%  BA='+(BA*100).toFixed(1)+'%'+
            '  PA='+(PA*100).toFixed(1)+'%  UA='+(UA*100).toFixed(1)+'%');
      print('  F1='+(F1*100).toFixed(1)+'%  CSI='+(CSI*100).toFixed(1)+'%'+
            '  κ='+kap.toFixed(3));
      print('  NOTE: All-land chips (no flood pixels) excluded from fold metrics.');
      print('  Interpretation: κ measures S1-only RF generalisation across India chips.');
      runStage2();
    }

    function cvFoldStep(foldIdx) {
      if (foldIdx >= nChips) {
        printCVAggregate();
        return;
      }

      var holdoutStem = allStems[foldIdx];
      var trnPts = s11_allPts.filter(ee.Filter.neq('chip_stem', holdoutStem));
      var valPts = s11_allPts.filter(ee.Filter.eq('chip_stem',  holdoutStem));

      var clfK = ee.Classifier.smileRandomForest({
        numberOfTrees: RF_TREES, variablesPerSplit: 2,
        minLeafPopulation: 5, seed: 42
      }).setOutputMode('PROBABILITY')
        .train({features: trnPts, classProperty: 'class', inputProperties: S11_FEAT});

      valPts.classify(clfK, 'prob')
        .map(function(f){
          var pred = ee.Number(f.get('prob')).gte(THR.rf_prob).toInt();
          var act  = ee.Number(f.get('class'));
          return f.set({
            TP: pred.eq(1).and(act.eq(1)).toInt(),
            TN: pred.eq(0).and(act.eq(0)).toInt(),
            FP: pred.eq(1).and(act.eq(0)).toInt(),
            FN: pred.eq(0).and(act.eq(1)).toInt()
          });
        })
        .evaluate(function(fc, ferr) {
          if (ferr || !fc) {
            print('  [CV fold ERROR] Chip '+holdoutStem+': '+ferr);
            cvFoldStep(foldIdx + 1);
            return;
          }

          var fTP=0,fTN=0,fFP=0,fFN=0;
          fc.features.forEach(function(f){
            fTP += f.properties.TP||0;
            fTN += f.properties.TN||0;
            fFP += f.properties.FP||0;
            fFN += f.properties.FN||0;
          });
          var tot = fTP+fTN+fFP+fFN;

          if ((fTP + fFN) === 0) {
            print('  Fold '+(foldIdx+1)+'/'+nChips+' (held: '+holdoutStem+
                  ') | SKIPPED — no flood pixels in holdout chip');
            cvFoldStep(foldIdx + 1);
            return;
          }

          var pa  = (fTP/(fTP+fFN)*100).toFixed(1);
          var ua  = (fTP+fFP)>0 ? (fTP/(fTP+fFP)*100).toFixed(1) : '0.0';
          var f1  = (2*fTP+fFP+fFN)>0 ? (2*fTP/(2*fTP+fFP+fFN)*100).toFixed(1) : '0.0';
          print('  Fold '+(foldIdx+1)+'/'+nChips+' (held: '+holdoutStem+')'+
                ' | n='+tot+' | PA='+pa+'% UA='+ua+'% F1='+f1+'%');

          cvTP += fTP; cvTN += fTN; cvFP += fFP; cvFN += fFN;
          cvFoldStep(foldIdx + 1);
        });
    }

    cvFoldStep(0);

    // =========================================================================
    // STAGE 2 + ALL DOWNSTREAM  (called from printCVAggregate)
    // =========================================================================

    function runStage2() {

      var featureStack = featureStackBase
        .addBands(s11_prob_roumari.unmask(THR.rf_fill))
        .clip(AOI);

      var sarWater = vhFlood.lt(otsuVH.subtract(THR.rf_water_m))
        .and(vhTexture.lt(THR.texture_max))
        .updateMask(nonRiverMask).rename('class');

      var sarLand = vhFlood.gt(otsuVH.add(THR.rf_land_m))
        .updateMask(nonRiverMask).rename('class');

      // ── Spatial CV blocks ─────────────────────────────────────────────────
      var bounds = AOI.bounds();
      var coords = ee.List(bounds.coordinates().get(0));
      var xMin   = ee.Number(ee.List(coords.get(0)).get(0));
      var yMin   = ee.Number(ee.List(coords.get(0)).get(1));
      var xMax   = ee.Number(ee.List(coords.get(2)).get(0));
      var yMax   = ee.Number(ee.List(coords.get(2)).get(1));
      var xStep  = xMax.subtract(xMin).divide(CV_COLS);
      var yStep  = yMax.subtract(yMin).divide(CV_ROWS);

      var blocks = [];
      for (var r=0; r<CV_ROWS; r++) {
        for (var c=0; c<CV_COLS; c++) {
          blocks.push(ee.Feature(ee.Geometry.Rectangle([
            xMin.add(xStep.multiply(c)),   yMin.add(yStep.multiply(r)),
            xMin.add(xStep.multiply(c+1)), yMin.add(yStep.multiply(r+1))
          ]), {fold: r*CV_COLS+c}));
        }
      }
      var blockFC   = ee.FeatureCollection(blocks);
      var foldImage = ee.Image(0).paint(blockFC,'fold').rename('fold').clip(AOI);

      Map.addLayer(blockFC, {color:'orange'}, '0. CV Blocks', false);

      var wPts = sarWater.selfMask().addBands(foldImage).addBands(featureStack)
        .stratifiedSample({numPoints:600, classBand:'class',
          region:AOI, scale:30, seed:42, geometries:true})
        .map(function(f){ return f.set('class',1); });

      var lPts = sarLand.selfMask().addBands(foldImage).addBands(featureStack)
        .stratifiedSample({numPoints:600, classBand:'class',
          region:AOI, scale:30, seed:43, geometries:true})
        .map(function(f){ return f.set('class',0); });

      var allPts = wPts.merge(lPts);

      print('');
      print('  ── STAGE 2 LOCAL RF — SPATIAL BLOCK CV ('+CV_ROWS+'×'+CV_COLS+' folds) ─────────────');

      var nFolds  = CV_ROWS * CV_COLS;
      var cvFolds = [];

      for (var k=0; k<nFolds; k++) {
        var trnK = allPts.filter(ee.Filter.neq('fold', k));
        var valK = allPts.filter(ee.Filter.eq('fold',  k));
        var clfK2 = ee.Classifier.smileRandomForest({
          numberOfTrees:RF_TREES, variablesPerSplit:3, minLeafPopulation:5, seed:42
        }).setOutputMode('PROBABILITY')
          .train({features:trnK, classProperty:'class', inputProperties:RF_FEAT});
        cvFolds.push(
          valK.classify(clfK2,'prob').map(function(f){
            return f.set('predicted', ee.Number(f.get('prob')).gte(THR.rf_prob).toInt());
          })
        );
      }

      var cvAll = cvFolds[0];
      for (var k2=1; k2<nFolds; k2++) { cvAll = cvAll.merge(cvFolds[k2]); }

      var cvLabelled = cvAll.map(function(f){
        var pred = ee.Number(f.get('predicted'));
        var act  = ee.Number(f.get('class'));
        return f.set({
          TP: pred.eq(1).and(act.eq(1)).toInt(),
          TN: pred.eq(0).and(act.eq(0)).toInt(),
          FP: pred.eq(1).and(act.eq(0)).toInt(),
          FN: pred.eq(0).and(act.eq(1)).toInt()
        });
      });

      ee.Dictionary({
        TP: cvLabelled.aggregate_sum('TP'), TN: cvLabelled.aggregate_sum('TN'),
        FP: cvLabelled.aggregate_sum('FP'), FN: cvLabelled.aggregate_sum('FN')
      }).evaluate(function(cv, err){
        if(err||!cv){ print('  [Stage 2 CV ERROR] '+err); return; }
        var TP=cv.TP,TN=cv.TN,FP=cv.FP,FN=cv.FN,tot=TP+TN+FP+FN;
        var OA=(TP+TN)/tot, PA=TP/(TP+FN), UA=TP/(TP+FP);
        var F1=2*TP/(2*TP+FP+FN), CSI=TP/(TP+FP+FN);
        var pe=((TP+FP)*(TP+FN)+(TN+FN)*(TN+FP))/(tot*tot);
        var kap=(OA-pe)/(1-pe);
        print('');
        print('  ── STAGE 2 SPATIAL BLOCK CV RESULTS ('+CV_ROWS+'×'+CV_COLS+' folds) ──────────────');
        print('  Labels: SAR-native Otsu. Features: SAR + terrain + JRC + s11_prob.');
        print('  n='+tot+' | TP='+TP+' TN='+TN+' FP='+FP+' FN='+FN);
        print('  OA='+(OA*100).toFixed(1)+'%  PA='+(PA*100).toFixed(1)+
              '%  UA='+(UA*100).toFixed(1)+'%');
        print('  F1='+(F1*100).toFixed(1)+'%  CSI='+(CSI*100).toFixed(1)+
              '%  κ='+kap.toFixed(3));
        print('  NOTE: Near-perfect κ is EXPECTED — labels are SAR-Otsu-derived');
        print('  "easy" pixels (±2 dB margin from threshold). This CV tests');
        print('  within-distribution label consistency, NOT real-world flood');
        print('  detection accuracy. Independent accuracy is reported in Sec 6a/6b.');
      });

      // ── Final Stage 2 classifiers ─────────────────────────────────────────
      var rfClf = ee.Classifier.smileRandomForest({
        numberOfTrees:RF_TREES, variablesPerSplit:3, minLeafPopulation:5, seed:42
      }).setOutputMode('PROBABILITY')
        .train({features:allPts, classProperty:'class', inputProperties:RF_FEAT});

      var rfClfClass = ee.Classifier.smileRandomForest({
        numberOfTrees:RF_TREES, variablesPerSplit:3, minLeafPopulation:5, seed:42
      }).setOutputMode('CLASSIFICATION')
        .train({features:allPts, classProperty:'class', inputProperties:RF_FEAT});

      rfClfClass.explain().evaluate(function(exp, err) {
        if (err || !exp || !exp.importance) {
          print('  [Stage 2 importance ERROR] ' + err); return;
        }
        var imp   = exp.importance;
        var pairs = RF_FEAT.map(function(f){ return {feature:f, importance:imp[f]||0}; });
        pairs.sort(function(a,b){ return b.importance-a.importance; });
        var total = pairs.reduce(function(s,p){ return s+p.importance; },0);
        print('');
        print('  ── STAGE 2 (Local RF) FEATURE IMPORTANCE ────────────────────────────');
        pairs.forEach(function(p){
          var norm = total>0 ? p.importance/total : 0;
          var pct  = (norm*100).toFixed(1);
          var bl   = Math.round(norm*30);
          var bar  = '';
          for(var i=0;i<bl;i++) bar+='█';
          for(var j=bl;j<30;j++) bar+='░';
          var note = p.feature==='s11_prob' ? ' ← Sen1Floods11 contribution' : '';
          print('  '+lp(p.feature,22)+lp(pct+'%',12)+bar+note);
        });
      });

      var rfProb = featureStack.classify(rfClf).updateMask(s1Mask).rename('rf_prob');

      rfProb.reduceRegion({
        reducer: ee.Reducer.percentile([10,25,50,75,90]),
        geometry:AOI, scale:30, maxPixels:1e10, bestEffort:true
      }).evaluate(function(d,e){
        if(e||!d){ print('  [RF prob ERROR] '+e); return; }
        print('  p10='+Number(d.rf_prob_p10).toFixed(2)+
              '  p25='+Number(d.rf_prob_p25).toFixed(2)+
              '  p50='+Number(d.rf_prob_p50).toFixed(2)+
              '  p75='+Number(d.rf_prob_p75).toFixed(2)+
              '  p90='+Number(d.rf_prob_p90).toFixed(2));
      });

      var rfBin   = rfProb.gte(THR.rf_prob).toInt().rename('flood');
      var rfMorph = rfBin.focal_median(15,'circle','meters').focal_mode(30,'circle','meters');
      var rfMskd  = rfMorph.updateMask(flatMask).updateMask(nonVegMask).updateMask(nonRiverMask)
        .gte(0.5).toInt().rename('flood');
      var rfConn  = rfMskd.connectedPixelCount({maxSize:256, eightConnected:true});
      var floodMap_RF = rfMskd.updateMask(rfConn.gte(THR.min_patch_px));

      countPx(rfProb.gte(THR.rf_prob).rename('f'), 'C-RF(Stage2) raw');
      countPx(floodMap_RF, 'C-RF(Stage2) final');

      Map.addLayer(rfProb,
        {min:0,max:1,palette:['white','#a9d18e','#375623']}, '4b. C-RF Prob (Stage 2)', false);
      Map.addLayer(floodMap_RF.selfMask(),
        {palette:['#27ae60']}, '4b. C-RF Map (Stage 2)', true);

      // ── Method D — Ensemble (run for reference; not a manuscript method) ──
      var voteSum  = floodMap_VH.unmask(0).add(floodMap_Otsu.unmask(0)).add(floodMap_RF.unmask(0));
      var ensRaw   = voteSum.gte(2).updateMask(nonRiverMask).toInt().rename('flood');
      var ensConn  = ensRaw.connectedPixelCount({maxSize:256, eightConnected:true});
      var floodMap_Ens = ensRaw.updateMask(ensConn.gte(THR.min_patch_px));

      countPx(floodMap_Ens, 'D-Ensemble final');
      Map.addLayer(floodMap_Ens.selfMask(), {palette:['#e91e8c']}, '5. D-Ensemble (ref only)', true);

      // ── Optical References ────────────────────────────────────────────────
      function maskL8(img){
        var qa=img.select('QA_PIXEL');
        return img.updateMask(qa.bitwiseAnd(1<<3).eq(0).and(qa.bitwiseAnd(1<<4).eq(0)));
      }

      var s2Ext = ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')
        .filterBounds(AOI).filterDate(DATE.opt_ext_start, DATE.opt_ext_end)
        .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', THR.max_cloud_s2))
        .select(['B3','B8','B11','SCL'])
        .map(function(img){ return img.clip(AOI); });

      var s2WaterExt = s2Ext.map(maskS2Clouds).map(function(img){
        return img.normalizedDifference(['B3','B8']).gt(THR.ndwi)
          .or(img.normalizedDifference(['B3','B11']).gt(THR.mndwi))
          .rename('water');
      });

      var l8Ext = ee.ImageCollection('LANDSAT/LC08/C02/T1_L2')
        .filterBounds(AOI).filterDate(DATE.opt_ext_start, DATE.opt_ext_end)
        .filter(ee.Filter.lt('CLOUD_COVER', THR.max_cloud_l8))
        .select(['SR_B3','SR_B5','SR_B6','QA_PIXEL'])
        .map(function(img){ return img.clip(AOI); });

      var l8WaterExt = l8Ext.map(maskL8).map(function(img){
        var g=img.select('SR_B3').multiply(0.0000275).add(-0.2);
        var n=img.select('SR_B5').multiply(0.0000275).add(-0.2);
        var s=img.select('SR_B6').multiply(0.0000275).add(-0.2);
        return g.subtract(n).divide(g.add(n)).gt(THR.ndwi)
          .or(g.subtract(s).divide(g.add(s)).gt(THR.mndwi)).rename('water');
      });

      var allOptExt  = s2WaterExt.merge(l8WaterExt);
      var obsExt     = allOptExt.count().clip(AOI).rename('obs');
      var freqExt    = allOptExt.sum().divide(obsExt);
      var refMaskExt = obsExt.gte(THR.min_obs).and(nonRiverMask);
      var wMaxExt    = allOptExt.max().updateMask(refMaskExt).rename('water_max');

      var s2Res = ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')
        .filterBounds(AOI).filterDate(DATE.opt_res_start, DATE.opt_res_end)
        .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', THR.max_cloud_s2))
        .select(['B3','B8','B11','SCL'])
        .map(function(img){ return img.clip(AOI); });

      var s2WaterRes = s2Res.map(maskS2Clouds).map(function(img){
        return img.normalizedDifference(['B3','B8']).gt(THR.ndwi)
          .or(img.normalizedDifference(['B3','B11']).gt(THR.mndwi)).rename('water');
      });

      var l8Res = ee.ImageCollection('LANDSAT/LC08/C02/T1_L2')
        .filterBounds(AOI).filterDate(DATE.opt_res_start, DATE.opt_res_end)
        .filter(ee.Filter.lt('CLOUD_COVER', THR.max_cloud_l8))
        .select(['SR_B3','SR_B5','SR_B6','QA_PIXEL'])
        .map(function(img){ return img.clip(AOI); });

      var l8WaterRes = l8Res.map(maskL8).map(function(img){
        var g=img.select('SR_B3').multiply(0.0000275).add(-0.2);
        var n=img.select('SR_B5').multiply(0.0000275).add(-0.2);
        var s=img.select('SR_B6').multiply(0.0000275).add(-0.2);
        return g.subtract(n).divide(g.add(n)).gt(THR.ndwi)
          .or(g.subtract(s).divide(g.add(s)).gt(THR.mndwi)).rename('water');
      });

      var allOptRes  = s2WaterRes.merge(l8WaterRes);
      var obsRes     = allOptRes.count().clip(AOI).rename('obs');
      var freqRes    = allOptRes.sum().divide(obsRes);
      var refMaskRes = obsRes.gte(THR.min_obs).and(nonRiverMask);
      var wMaxRes    = allOptRes.max().updateMask(refMaskRes).rename('water_max');

      function maskMODIS(img){
        return img.updateMask(img.select('state_1km').bitwiseAnd(3).eq(0));
      }
      var modisCol = ee.ImageCollection('MODIS/061/MOD09GA')
        .filterBounds(AOI).filterDate(DATE.opt_ext_start, DATE.opt_ext_end)
        .select(['sur_refl_b04','sur_refl_b02','sur_refl_b06','state_1km'])
        .map(function(img){ return img.clip(AOI); });
      var modisWater = modisCol.map(maskMODIS).map(function(img){
        var g=img.select('sur_refl_b04').multiply(0.0001);
        var n=img.select('sur_refl_b02').multiply(0.0001);
        var s=img.select('sur_refl_b06').multiply(0.0001);
        return g.subtract(n).divide(g.add(n)).gt(THR.ndwi)
          .or(g.subtract(s).divide(g.add(s)).gt(THR.mndwi)).rename('water');
      });
      var modisObs = modisWater.count().clip(AOI).rename('obs');
      var modisMax = modisWater.max().updateMask(modisObs.gte(THR.min_obs)).rename('wm');

      Map.addLayer(freqExt, {min:0,max:1,palette:['#f5e642','#27b0e6','#0a4e9e']},
        '0. S2+L8 Freq (Extended)', false);
      Map.addLayer(wMaxExt.selfMask(), {palette:['#1a3a8a']}, '0. S2+L8 Max Ext', false);
      Map.addLayer(wMaxRes.selfMask(), {palette:['#2874a6']}, '0. S2+L8 Max Res', false);

      // ── Validation Points ─────────────────────────────────────────────────
      function makePts(wMask, lMask, nW, nL, sW, sL, strat) {
        var wP = wMask.selfMask().stratifiedSample({
          numPoints:nW, classBand:wMask.bandNames().get(0),
