        ['GFM           ', gfmSmoothed]
      ];

      var accSections = [
        ['EXTENDED — 50% PERSISTENCE  (main result)', vPts50e, 'Ext 50%  '],
        ['EXTENDED — 60% PERSISTENCE',                vPts60e, 'Ext 60%  '],
        ['EXTENDED — MAXIMUM EXTENT',                 vPtsMaxE,'Ext max  '],
        ['EXTENDED — CROPLAND ONLY',                  vPtsCrop,'Crop 50% '],
        ['RESTRICTED — 50% PERSISTENCE  ★',           vPts50r, 'Res 50% ★'],
        ['RESTRICTED — MAXIMUM EXTENT  ★',            vPtsMaxR,'Res max ★']
      ];

      function runMethodStep(secIdx, mIdx) {
        if (mIdx >= accMethods.length) {
          runAccSection(secIdx + 1);
          return;
        }
        var am  = accMethods[mIdx];
        var sec = accSections[secIdx];
        calcMetrics(am[1], sec[1], am[0]+'|'+sec[2]).evaluate(function(m, err) {
          if (err || !m) {
            print('  [ACC ERROR] ' + am[0].trim() + ': ' + err);
            runMethodStep(secIdx, mIdx + 1);
            return;
          }
          rowFmt(m);
          runMethodStep(secIdx, mIdx + 1);
        });
      }

      function runAccSection(secIdx) {
        if (secIdx >= accSections.length) {
          runThresholdSweep();
          return;
        }
        if (secIdx === 0) {
          print('');
          print('═══════════════════════════════════════════════════════════════════════════');
          print('  6a. ACCURACY — EXTENDED WINDOW');
          print('═══════════════════════════════════════════════════════════════════════════');
        }
        if (secIdx === 4) {
          print('');
          print('═══════════════════════════════════════════════════════════════════════════');
          print('  6b. ACCURACY — RESTRICTED WINDOW  ★ GFM-FAIR');
          print('═══════════════════════════════════════════════════════════════════════════');
        }
        print(''); print('  ── ' + accSections[secIdx][0]); print(hdr); print(div);
        runMethodStep(secIdx, 0);
      }

      function runThresholdSweep() {
        print('');
        print('  ── STAGE 2 RF PROBABILITY THRESHOLD SWEEP (Ext 50% validation) ──────');
        print('  ' + lp('t',5) + lp('px',8) + lp('ha',7) +
              lp('BA',8) + lp('PA',8) + lp('UA',8) +
              lp('F1',8) + lp('CSI',8) + lp('κ',8) +
              ' ← t=' + THR.rf_prob + ' is production');
        print('  ' + Array(75).join('-'));

        var thresholds = [0.3, 0.4, 0.5, 0.6, 0.7];

        function sweepStep(idx) {
          if (idx >= thresholds.length) {
            runSec7();
            return;
          }
          var t = thresholds[idx];
          var rfBinT = rfProb.gte(t).toInt().rename('flood');
          rfBinT.selfMask().rename('f')
            .reduceRegion({reducer: ee.Reducer.count(), geometry: AOI,
                           scale: 30, maxPixels: 1e10, bestEffort: true})
            .evaluate(function(r, er) {
              var px = (er || !r) ? 'ERR' : r.f;
              var ha = (er || !r || !r.f) ? 'N/A' : ((r.f * 900) / 10000).toFixed(0);
              calcMetrics(rfBinT, vPts50e, 'sweep|t' + t).evaluate(function(m, me) {
                if (me || !m) {
                  print('  t=' + t + ' ERROR: ' + me);
                  sweepStep(idx + 1); return;
                }
                var pc = function(v){ return lp((!v&&v!==0)||isNaN(v)?'N/A':(v*100).toFixed(1)+'%',8); };
                var kf = function(v){ return lp((!v&&v!==0)||isNaN(v)?'N/A':v.toFixed(3),8); };
                var mk = Math.abs(t - THR.rf_prob) < 0.001 ? ' ← PRODUCTION' : '';
                print('  ' + lp(t.toFixed(1),5) + lp(String(px),8) + lp(String(ha),7) +
                      pc(m.BA) + pc(m.PA) + pc(m.UA) + pc(m.F1) + pc(m.CSI) + kf(m.Kappa) + mk);
                sweepStep(idx + 1);
              });
            });
        }
        sweepStep(0);
      }

      // ── Section 7: Spatial comparison vs GFM ─────────────────────────────
      function runSec7() {
        print('');
        print('═══════════════════════════════════════════════════════════════════════════');
        print('  7. SPATIAL COMPARISON: OUR METHODS vs GFM');
        print('  Agree=both detect | Our-only | GFM-only: JRC-wet vs non-JRC');
        print('═══════════════════════════════════════════════════════════════════════════');

        var gfmB        = gfmSmoothed.unmask(0);
        var jrcWetMask0 = jrcWetMask.unmask(0);

        function a30(img, band) {
          return img.rename(band).multiply(ee.Image.pixelArea())
            .reduceRegion({reducer: ee.Reducer.sum(), geometry: AOI,
                           scale: 30, maxPixels: 1e10}).get(band);
        }

        var methods7 = [
          ['A-VH Change',   floodMap_VH],
          ['B-VV Change',   floodMap_VV],
          ['C-MultiPol',    floodMap_MP],
          ['B-Otsu',        floodMap_Otsu],
          ['C-RF-S11(St1)', floodMap_S11],
          ['C-RF (St2)',    floodMap_RF],
          ['D-Ensemble',    floodMap_Ens]
        ];

        function sec7Step(idx) {
          if (idx >= methods7.length) {
            Map.addLayer(floodMap_Ens.unmask(0).and(gfmB).selfMask(),
              {palette:['#2ecc71']}, '7. Ens∩GFM agree', false);
            Map.addLayer(floodMap_Ens.unmask(0).and(gfmB.not()).selfMask(),
              {palette:['#3498db']}, '7. Ens-only', false);
            var gOE = gfmB.and(floodMap_Ens.unmask(0).not());
            Map.addLayer(gOE.and(jrcWetMask0).selfMask(),       {palette:['#e67e22']}, '7. GFM-only JRC-wet',  false);
            Map.addLayer(gOE.and(jrcWetMask0.not()).selfMask(), {palette:['#e74c3c']}, '7. GFM-only non-JRC',  false);
            print('');
            print('  ✓ v15 COMPLETE  |  Year: ' + YEAR);
            print('  Stage 1: '+matchedS1Ids.length+' chip pairs → S1-only RF → s11_prob');
            print('  Stage 2: Local RF (11 features incl. VH_flood) + s11_prob → C-RF map');
            print('  B-VV   : VV per-scene Otsu change detection');
            print('  C-MP   : VV+VH pooled freq fusion (threshold='+THR.mp_freq_min+')');
            print('  Exports: NONE (removed in v15)');
            return;
          }
          var m7    = methods7[idx];
          var ourB  = m7[1].unmask(0);
          var ag    = ourB.and(gfmB);
          var ou    = ourB.and(gfmB.not());
          var gf    = gfmB.and(ourB.not());
          var gfJ   = gf.and(jrcWetMask0);
          var gfN   = gf.and(jrcWetMask0.not());
          ee.Dictionary({
            ag: a30(ag,'f'), ou: a30(ou,'f'),
            gf: a30(gf,'f'), gfJ: a30(gfJ,'f'), gfN: a30(gfN,'f'),
            gt: a30(gfmB,'gfm')
          }).evaluate(function(d, err) {
            if (err || !d) { print('  [Comp ERROR] '+m7[0]+': '+err); sec7Step(idx+1); return; }
            var cap     = (d.ag&&d.gt) ? (d.ag/d.gt*100).toFixed(1)+'%' : 'N/A';
            var jPct    = d.gf>0 ? (d.gfJ/d.gf*100).toFixed(0) : 'N/A';
            var nPct    = d.gf>0 ? (d.gfN/d.gf*100).toFixed(0) : 'N/A';
            var resid   = d.gf>0 ? (d.gf-d.gfJ-d.gfN)/10000 : 0;
            var note    = Math.abs(resid)<10 ? '✓ sum=100%' : '⚠ residual='+resid.toFixed(0)+' ha';
            print('  '+lp(m7[0],18)+' | Agree='+rp(fha(d.ag),7)+' ha'+
                  ' | Our-only='+rp(fha(d.ou),7)+' ha'+
                  ' | GFM-only='+rp(fha(d.gf),7)+' ha | GFM capture='+cap);
            print('    GFM-only: JRC-wet='+fha(d.gfJ)+' ha ('+jPct+
                  '%)  non-JRC='+fha(d.gfN)+' ha ('+nPct+'%)  ['+note+']');
            sec7Step(idx+1);
          });
        }
        sec7Step(0);
      }

