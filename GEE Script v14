function countPx(img, label) {
  img.rename('f').selfMask()
    .reduceRegion({reducer:ee.Reducer.count(),geometry:AOI,scale:30,maxPixels:1e10,bestEffort:true})
    .evaluate(function(r,e){
      if(e||!r){ print('  [px] '+label+' ERROR'); return; }
      print('  [px] '+label+': '+r.f+' px ('+((r.f*900)/10000).toFixed(0)+' ha)');
    });
}

function areaHa(img, band, sc) {
  return img.rename(band).multiply(ee.Image.pixelArea())
    .reduceRegion({reducer:ee.Reducer.sum(),geometry:AOI,scale:sc||10,maxPixels:1e10})
    .get(band);
}

function lp(s,w){ s=String(s); while(s.length<w) s=s+' '; return s; }
function rp(s,w){ s=String(s); while(s.length<w) s=' '+s; return s; }
function fha(v)   { return v   ? (v/10000).toFixed(1)    : 'N/A'; }
function fpct(v,d){ return (v&&d) ? (v/d*100).toFixed(1)+'%' : 'N/A'; }
function frat(v,d){ return (v&&d) ? (v/d).toFixed(2)     : 'N/A'; }

// =============================================================================
// 8. POST-PROCESSING PIPELINE
// =============================================================================

function postProcess(rawFlood, name) {
  var s0 = rawFlood.rename('flood');
  countPx(s0, name+' raw');
  var s1s = s0.focal_median(15,'circle','meters').focal_mode(30,'circle','meters');
  var s2s = s1s.updateMask(flatMask);
  var s3s = s2s.updateMask(vhTexture.lt(THR.texture_max));
  var s4s = s3s.updateMask(nonVegMask);
  var s5s = s4s.updateMask(nonRiverMask).gte(0.5).toInt().rename('flood');
  var conn  = s5s.connectedPixelCount({maxSize:256, eightConnected:true});
  var final = s5s.updateMask(conn.gte(THR.min_patch_px));
  countPx(final, name+' final');
  return final;
}

// =============================================================================
// 9. OTSU THRESHOLDS
// =============================================================================

function otsu(histDict) {
  var hist    = ee.Dictionary(histDict);
  var counts  = ee.Array(hist.get('histogram'));
  var means   = ee.Array(hist.get('bucketMeans'));
  var mList   = ee.List(hist.get('bucketMeans'));
  var size    = means.length().get([0]);
  var total   = counts.reduce(ee.Reducer.sum(),[0]).get([0]);
  var between = ee.List.sequence(1, size.subtract(1)).map(function(i){
    i = ee.Number(i).toInt();
    var aC = counts.slice(0,0,i), bC = counts.slice(0,i);
    var aN = aC.reduce(ee.Reducer.sum(),[0]).get([0]);
    var bN = bC.reduce(ee.Reducer.sum(),[0]).get([0]);
    var aM = means.slice(0,0,i).multiply(aC).reduce(ee.Reducer.sum(),[0]).get([0]).divide(aN);
    var bM = means.slice(0,i).multiply(bC).reduce(ee.Reducer.sum(),[0]).get([0]).divide(bN);
    return aN.multiply(bN).multiply(aM.subtract(bM).pow(2)).divide(total.pow(2));
  });
  var mx = between.reduce(ee.Reducer.max());
  return ee.Number(mList.get(between.indexOf(mx).add(1)));
}

// Otsu on VH change (used by A-VH, B-Otsu, C-MultiPol VH stack)
