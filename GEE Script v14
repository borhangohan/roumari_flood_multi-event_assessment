      // ── Accuracy metric function ──────────────────────────────────────────
      function calcMetrics(floodMap, valPts, label) {
        var sampledMap = floodMap.rename('flood').unmask(0);
        var cm = sampledMap.sampleRegions({
          collection: valPts, scale: 30, tileScale: 4, geometries: false
        }).map(function(f){
          var pred = ee.Number(f.get('flood')).round();
          var act  = ee.Number(f.get('class'));
          return f.set({
            TP: pred.eq(1).and(act.eq(1)).toInt(),
            TN: pred.eq(0).and(act.eq(0)).toInt(),
            FP: pred.eq(1).and(act.eq(0)).toInt(),
            FN: pred.eq(0).and(act.eq(1)).toInt()
          });
        });

        var TP  = ee.Number(cm.aggregate_sum('TP'));
        var TN  = ee.Number(cm.aggregate_sum('TN'));
        var FP  = ee.Number(cm.aggregate_sum('FP'));
        var FN  = ee.Number(cm.aggregate_sum('FN'));
        var tot = TP.add(TN).add(FP).add(FN);
        var OA  = TP.add(TN).divide(tot);
        var PA  = TP.divide(TP.add(FN));
        var UA  = TP.divide(TP.add(FP));
        var specLand = TN.divide(TN.add(FP));
        var BA  = PA.add(specLand).divide(2);
        var F1  = TP.multiply(2).divide(TP.multiply(2).add(FP).add(FN));
        var CSI = TP.divide(TP.add(FP).add(FN));
        var pe  = TP.add(FP).multiply(TP.add(FN))
                    .add(TN.add(FN).multiply(TN.add(FP)))
                    .divide(tot.pow(2));
        var kap = OA.subtract(pe).divide(ee.Number(1).subtract(pe));

        return ee.Dictionary({
          label:label, TP:TP, TN:TN, FP:FP, FN:FN,
          OA:OA, BA:BA, PA:PA, UA:UA, F1:F1, CSI:CSI, Kappa:kap, total:tot
        });
      }

      var hdr = '  '+lp('Method',16)+'| '+lp('Validation set',17)+'| '+
        rp('n',4)+' '+rp('TP',4)+' '+rp('TN',4)+' '+rp('FP',4)+' '+rp('FN',4)+' | '+
        rp('BA',7)+' '+rp('PA',7)+' '+rp('UA',7)+' | '+
        rp('F1',7)+' '+rp('CSI',7)+' '+rp('κ',6);
      var div = '  '+Array(116).join('-');

      function rowFmt(m){
        if(!m){ print('  [row error]'); return; }
        var p  = m.label.split('|');
        var pc = function(v){ return rp((!v&&v!==0)||isNaN(v)?'N/A':(v*100).toFixed(1)+'%',7); };
        var kf = function(v){ return rp((!v&&v!==0)||isNaN(v)?'N/A':v.toFixed(3),6); };
        var n  = (m.TP!==undefined&&m.TN!==undefined&&m.FP!==undefined&&m.FN!==undefined)
                 ? m.TP+m.TN+m.FP+m.FN : '?';
        print('  '+lp(p[0].trim(),16)+'| '+lp(p[1].trim(),17)+'| '+
          rp(n,4)+' '+rp(m.TP,4)+' '+rp(m.TN,4)+' '+rp(m.FP,4)+' '+rp(m.FN,4)+' | '+
          pc(m.BA)+' '+pc(m.PA)+' '+pc(m.UA)+' | '+
          pc(m.F1)+' '+pc(m.CSI)+' '+kf(m.Kappa));
      }

      // Accuracy tables include all methods (manuscript + reference-only)
      var accMethods = [
        ['A-VH          ', floodMap_VH],
        ['B-VV          ', floodMap_VV],
        ['C-MultiPol    ', floodMap_MP],
        ['B-Otsu        ', floodMap_Otsu],
