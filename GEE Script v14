// =============================================================================
// 14. METHOD C-MULTIPOL — MULTI-POLARISATION FREQUENCY FUSION
// =============================================================================
// Structural parallel to the S2+L8 optical validation approach:
//
//   Optical validation:
//     S2/L8 scenes → per-image NDWI/MNDWI binary → flood frequency
//     Threshold ≥ 0.5 → validated as flooded
//
//   Multi-pol fusion:
//     VH scenes → per-scene Otsu binary  (changePerScene)
//     VV scenes → per-scene Otsu binary  (changePerScene_VV)
//     Merged stack → freq = flooded_count / (n_VH + n_VV scenes)
//     Threshold ≥ THR.mp_freq_min (0.5) → classified as flooded
//
//   Frequency interpretation:
//     Both polarisations, all scenes → freq ≈ 1.0
//     Single-polarisation only (e.g. flooded veg in VH) → freq ≈ 0.5  (passes)
//     Single-scene noise → max contribution ≈ 1/(2N) ≈ 0.1–0.17 (N≥3)

var vhSceneStack = changePerScene.map(function(img) {
  return img.lt(otsuChange).rename('flood_obs')
    .copyProperties(img, ['system:time_start']);
});

var vvSceneStack = changePerScene_VV.map(function(img) {
  return img.lt(otsuChange_VV).rename('flood_obs')
    .copyProperties(img, ['system:time_start']);
});

var allPolStack = vhSceneStack.merge(vvSceneStack);
var mpObs       = allPolStack.count().clip(AOI).rename('obs');
var mpSum       = allPolStack.sum().clip(AOI).rename('sum');
var mpFreq      = mpSum.divide(mpObs).rename('mp_freq');

var mpRaw       = mpFreq.gte(THR.mp_freq_min)
                    .updateMask(mpObs.gte(THR.min_obs))
                    .toInt().rename('flood');
var floodMap_MP = postProcess(mpRaw, 'C-MultiPol');

Map.addLayer(mpFreq,
  {min:0,max:1,palette:['white','#f9ca74','#c0392b']},
  '4. C-MultiPol Frequency', false);
Map.addLayer(floodMap_MP.selfMask(),
  {palette:['#e74c3c']}, '4. C-MultiPol Map', true);

mpObs.reduceRegion({
  reducer:ee.Reducer.mean(), geometry:AOI, scale:30, maxPixels:1e10, bestEffort:true
}).evaluate(function(d,e){
  if(e||!d){ print('  [MultiPol obs ERROR] '+e); return; }
  print('  MultiPol: mean obs/px = '+Number(d.obs).toFixed(1)+
        ' (VV+VH scenes pooled) | freq threshold: '+THR.mp_freq_min);
});

